# Copy this file to ops/codex/translation-batch.env and adjust local paths if needed.

BATCH_WORKDIR="/Users/tabber/Anthropic-Research-KR"
BATCH_LOG_DIR="/Users/tabber/Anthropic-Research-KR/logs/codex"
BATCH_STATE_DIR="/Users/tabber/Anthropic-Research-KR/tmp/codex"
BATCH_STOP_FILE="/Users/tabber/Anthropic-Research-KR/ops/codex/STOP"

# Translate one missing post per run by default so failures stay small.
BATCH_LIMIT="1"

# Leave blank to use the default configured Codex model.
BATCH_MODEL=""
BATCH_SANDBOX="workspace-write"
BATCH_GIT_PUSH_AFTER_RUN="0"
BATCH_GIT_REMOTE="origin"
BATCH_GIT_BRANCH="main"
BATCH_GIT_AUTHOR_NAME="IT learning"
BATCH_GIT_AUTHOR_EMAIL="yo7504@naver.com"

# Override only if node is elsewhere.
BATCH_NODE_BIN="node"

# Keep the default repo prompt unless you want a different translation behavior.
BATCH_PROMPT_FILE="/Users/tabber/Anthropic-Research-KR/ops/codex/translation-batch-prompt.md"

# Extra args pass straight through to scripts/run_translation_batch.mjs.
# Example:
# BATCH_EXTRA_ARGS="--dry-run"
BATCH_EXTRA_ARGS=""
